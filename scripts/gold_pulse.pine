// ============================================================
//
//    ██████╗  ██████╗ ██╗     ██████╗     ██████╗ ██╗   ██╗██╗     ███████╗███████╗
//   ██╔════╝ ██╔═══██╗██║     ██╔══██╗    ██╔══██╗██║   ██║██║     ██╔════╝██╔════╝
//   ██║  ███╗██║   ██║██║     ██║  ██║    ██████╔╝██║   ██║██║     ███████╗█████╗
//   ██║   ██║██║   ██║██║     ██║  ██║    ██╔═══╝ ██║   ██║██║     ╚════██║██╔══╝
//   ╚██████╔╝╚██████╔╝███████╗██████╔╝    ██║     ╚██████╔╝███████╗███████║███████╗
//    ╚═════╝  ╚═════╝ ╚══════╝╚═════╝     ╚═╝      ╚═════╝ ╚══════╝╚══════╝╚══════╝
//
// ============================================================
// XAUUSD Gold Pulse — Quiet Range Breakout Retest
// ============================================================
//
// The daily rhythm of gold:
//   1. QUIET  — price consolidates in a tight range (overnight)
//   2. BREAK  — price breaks above or below the range (Tokyo/London)
//   3. PULL   — price retests the breakout level (the entry)
//   4. PULSE  — price continues in the breakout direction (the trade)
//
// No RSI. No EMA. No VWAP. No MACD. No lagging indicators.
// Only price structure: range, breakout, retest, continuation.
//
// Built from 8 iterations of testing on XAUUSD 15m:
//   - Generic indicators: all failed (0-31% win rate)
//   - Sweep + reversal: signals went backwards on gold
//   - Inverted logic: breakouts continue, pullbacks are entries
//   - This indicator strips away everything except the proven edge
//
// Exchange: OANDA (America/New_York timezone)
// Timeframe: 15m (also works on 5m)
// ============================================================

//@version=5
indicator("Gold Pulse", overlay=true, max_labels_count=200, max_lines_count=100, max_boxes_count=50)

// ────────────────────────────────────────────────────────────
// INPUTS
// ────────────────────────────────────────────────────────────

// Quiet range — the foundation of every setup
quietStart = input.session("1800-2200", "Quiet Range Period (EDT)", group="Range",
     tooltip="The low-volatility window before Tokyo gets active. Builds the range that defines the day's levels. 18:00-22:00 EDT = 22:00-02:00 UTC.")

// Breakout
atrLen     = input.int(14, "ATR Length", minval=5, maxval=30, group="Breakout")
breakBuffer = input.float(0.2, "Breakout Buffer (x ATR)", minval=0.0, maxval=1.0, step=0.1, group="Breakout",
     tooltip="Price must close this far beyond the range to confirm a breakout. Filters false breaks.")

// Pullback entry
pullbackZone = input.float(0.5, "Pullback Zone (x ATR)", minval=0.1, maxval=2.0, step=0.1, group="Entry",
     tooltip="How close price must return to the breakout level to count as a pullback entry zone.")
requireCandleConfirm = input.bool(true, "Require Candle Confirmation", group="Entry",
     tooltip="Entry only fires on a candle that closes in the breakout direction (green for buys, red for sells).")

// Risk management
rrRatio    = input.float(1.5, "Reward:Risk Ratio", minval=1.0, maxval=5.0, step=0.5, group="Risk")
maxEntries = input.int(2, "Max Entries Per Day", minval=1, maxval=5, group="Risk")

// Sessions for background coloring
londonSess = input.session("0400-1300", "London (EDT)", group="Display")
nySess     = input.session("0900-1800", "New York (EDT)", group="Display")
showSessBG = input.bool(true, "Session Backgrounds", group="Display")
showSLTP   = input.bool(true, "Show Stop/Target Levels", group="Display")

// ────────────────────────────────────────────────────────────
// SESSION DETECTION
// ────────────────────────────────────────────────────────────

inQuiet  = not na(time(timeframe.period, quietStart))
inLondon = not na(time(timeframe.period, londonSess))
inNY     = not na(time(timeframe.period, nySess))

bgcolor(showSessBG and inQuiet  ? color.new(#1a1a2e, 80) : na, title="Quiet")
bgcolor(showSessBG and inLondon and not inQuiet ? color.new(#1a2a4a, 88) : na, title="London")
bgcolor(showSessBG and inNY and not inLondon    ? color.new(#2a1a0a, 88) : na, title="NY")

// ────────────────────────────────────────────────────────────
// QUIET RANGE (Step 1: The Setup)
// ────────────────────────────────────────────────────────────

var float rangeHigh    = na
var float rangeLow     = na
var bool  rangeLocked  = false

quietJustStarted = inQuiet and not inQuiet[1]
quietJustEnded   = not inQuiet and inQuiet[1]

if quietJustStarted
    rangeHigh   := high
    rangeLow    := low
    rangeLocked := false

if inQuiet and not rangeLocked
    rangeHigh := math.max(nz(rangeHigh, high), high)
    rangeLow  := math.min(nz(rangeLow, low), low)

if quietJustEnded
    rangeLocked := true

// Draw range — current day only
var line rangeHighLine = na
var line rangeLowLine  = na
var line rangeMidLine  = na

if quietJustEnded
    line.delete(rangeHighLine)
    line.delete(rangeLowLine)
    line.delete(rangeMidLine)
    rangeMid = (rangeHigh + rangeLow) / 2
    rangeHighLine := line.new(bar_index, rangeHigh, bar_index + 1, rangeHigh,
         color=color.new(#ef5350, 20), width=2, extend=extend.right)
    rangeLowLine  := line.new(bar_index, rangeLow, bar_index + 1, rangeLow,
         color=color.new(#66bb6a, 20), width=2, extend=extend.right)
    rangeMidLine  := line.new(bar_index, rangeMid, bar_index + 1, rangeMid,
         color=color.new(color.gray, 50), width=1, style=line.style_dotted, extend=extend.right)

// Cut lines at next quiet period
if quietJustStarted
    if not na(rangeHighLine)
        line.set_extend(rangeHighLine, extend.none)
        line.set_x2(rangeHighLine, bar_index)
    if not na(rangeLowLine)
        line.set_extend(rangeLowLine, extend.none)
        line.set_x2(rangeLowLine, bar_index)
    if not na(rangeMidLine)
        line.set_extend(rangeMidLine, extend.none)
        line.set_x2(rangeMidLine, bar_index)

// ────────────────────────────────────────────────────────────
// BREAKOUT DETECTION (Step 2: The Direction)
// ────────────────────────────────────────────────────────────

atrValue = ta.atr(atrLen)
breakThreshold = atrValue * breakBuffer

// Daily bias: set by FIRST breakout, locked for the day
// 1 = bullish breakout (above range), -1 = bearish breakout (below range), 0 = no breakout yet
var int dailyBias = 0
var int dailyEntryCount = 0
var float breakoutLevel = na    // the level price broke through

if quietJustStarted
    dailyBias := 0
    dailyEntryCount := 0
    breakoutLevel := na

// Bullish breakout: first close above range high + buffer
bullBreakout = rangeLocked and dailyBias == 0 and
     close > rangeHigh + breakThreshold

// Bearish breakout: first close below range low - buffer
bearBreakout = rangeLocked and dailyBias == 0 and
     close < rangeLow - breakThreshold

if bullBreakout
    dailyBias := 1
    breakoutLevel := rangeHigh

if bearBreakout
    dailyBias := -1
    breakoutLevel := rangeLow

// Mark breakout on chart
plotshape(bullBreakout, "Bull Breakout", shape.arrowup, location.belowbar,
     color=color.new(#00e676, 0), size=size.normal)
plotshape(bearBreakout, "Bear Breakout", shape.arrowdown, location.abovebar,
     color=color.new(#ff1744, 0), size=size.normal)

// ────────────────────────────────────────────────────────────
// PULLBACK ENTRY (Step 3: The Entry)
// ────────────────────────────────────────────────────────────

// Pullback zone: price returns close to the breakout level
pullbackDist = atrValue * pullbackZone

// For bullish: price pulls back DOWN toward rangeHigh
inBullPullback = dailyBias == 1 and
     not na(breakoutLevel) and
     low <= breakoutLevel + pullbackDist and
     close > breakoutLevel - pullbackDist

// For bearish: price pulls back UP toward rangeLow
inBearPullback = dailyBias == -1 and
     not na(breakoutLevel) and
     high >= breakoutLevel - pullbackDist and
     close < breakoutLevel + pullbackDist

// Candle confirmation
bullCandle = close > open
bearCandle = close < open

// Entry signal
bullEntry = inBullPullback and
     (requireCandleConfirm ? bullCandle : true) and
     dailyEntryCount < maxEntries and
     rangeLocked

bearEntry = inBearPullback and
     (requireCandleConfirm ? bearCandle : true) and
     dailyEntryCount < maxEntries and
     rangeLocked

// Only fire once per pullback (prevent multiple signals on consecutive bars in the zone)
var bool bullEntryFired = false
var bool bearEntryFired = false

if quietJustStarted
    bullEntryFired := false
    bearEntryFired := false

if bullBreakout
    bullEntryFired := false
if bearBreakout
    bearEntryFired := false

// Reset entry flag when price moves away from pullback zone (allows re-entry on next pullback)
if dailyBias == 1 and close > breakoutLevel + pullbackDist * 2
    bullEntryFired := false
if dailyBias == -1 and close < breakoutLevel - pullbackDist * 2
    bearEntryFired := false

bullSignal = bullEntry and not bullEntryFired
bearSignal = bearEntry and not bearEntryFired

if bullSignal
    bullEntryFired := true
    dailyEntryCount += 1
if bearSignal
    bearEntryFired := true
    dailyEntryCount += 1

// ────────────────────────────────────────────────────────────
// STOP / TARGET (Step 4: The Risk)
// ────────────────────────────────────────────────────────────

rangeMidVal = (rangeHigh + rangeLow) / 2

// Bull entry: stop at range midpoint, target at RR ratio above entry
var float bullStop   = na
var float bullTarget = na

// Bear entry: stop at range midpoint, target at RR ratio below entry
var float bearStop   = na
var float bearTarget = na

if bullSignal
    bullStop   := rangeMidVal
    risk       = close - rangeMidVal
    bullTarget := close + risk * rrRatio

if bearSignal
    bearStop   := rangeMidVal
    risk       = rangeMidVal - close
    bearTarget := close - risk * rrRatio

// Draw stop/target
if bullSignal and showSLTP
    label.new(bar_index, bullStop,   "SL",
         style=label.style_label_up, color=color.new(#ff5252, 20),
         textcolor=color.white, size=size.tiny)
    label.new(bar_index, bullTarget, "TP",
         style=label.style_label_down, color=color.new(#4caf50, 20),
         textcolor=color.white, size=size.tiny)

if bearSignal and showSLTP
    label.new(bar_index, bearStop,   "SL",
         style=label.style_label_down, color=color.new(#ff5252, 20),
         textcolor=color.white, size=size.tiny)
    label.new(bar_index, bearTarget, "TP",
         style=label.style_label_up, color=color.new(#4caf50, 20),
         textcolor=color.white, size=size.tiny)

// ────────────────────────────────────────────────────────────
// ENTRY SIGNALS
// ────────────────────────────────────────────────────────────

plotshape(bullSignal, "Buy Entry", shape.triangleup, location.belowbar,
     color=color.new(#00e676, 0), size=size.small, text="BUY", textcolor=color.white)
plotshape(bearSignal, "Sell Entry", shape.triangledown, location.abovebar,
     color=color.new(#ff1744, 0), size=size.small, text="SELL", textcolor=color.white)

// Color the entry bar
barcolor(bullSignal ? color.new(#00e676, 0) : na, title="Buy Bar")
barcolor(bearSignal ? color.new(#ff1744, 0) : na, title="Sell Bar")

// ────────────────────────────────────────────────────────────
// PULLBACK ZONE VISUALIZATION
// ────────────────────────────────────────────────────────────

// Shade the pullback zone so you can see where entries will trigger
var box pullbackBox = na

// Redraw pullback zone when breakout happens
if bullBreakout
    box.delete(pullbackBox)
    pullbackBox := box.new(bar_index, breakoutLevel + pullbackDist, bar_index + 200, breakoutLevel - pullbackDist,
         border_color=color.new(#00e676, 60), bgcolor=color.new(#00e676, 92),
         text="PULLBACK ZONE", text_color=color.new(#00e676, 50), text_size=size.tiny)

if bearBreakout
    box.delete(pullbackBox)
    pullbackBox := box.new(bar_index, breakoutLevel + pullbackDist, bar_index + 200, breakoutLevel - pullbackDist,
         border_color=color.new(#ff1744, 60), bgcolor=color.new(#ff1744, 92),
         text="PULLBACK ZONE", text_color=color.new(#ff1744, 50), text_size=size.tiny)

// Remove pullback zone at next quiet period
if quietJustStarted and not na(pullbackBox)
    box.delete(pullbackBox)

// ────────────────────────────────────────────────────────────
// DASHBOARD
// ────────────────────────────────────────────────────────────

if barstate.islast
    var table d = table.new(position.top_right, 2, 7,
         bgcolor=color.new(color.black, 10),
         border_color=color.new(color.gray, 50), border_width=1,
         frame_color=color.new(color.gray, 30), frame_width=2)

    gn = #00e676
    rd = #ff1744
    yl = color.yellow
    wh = color.white
    gr = color.gray

    table.cell(d, 0, 0, "GOLD", text_color=yl, text_size=size.normal, bgcolor=color.new(color.black, 0))
    table.cell(d, 1, 0, "PULSE", text_color=yl, text_size=size.normal, bgcolor=color.new(color.black, 0))

    // Phase
    phaseStr = inQuiet ? "QUIET (building)" :
               dailyBias == 0 and rangeLocked ? "WAITING FOR BREAK" :
               dailyBias == 1 ? "BULLISH BREAKOUT" :
               dailyBias == -1 ? "BEARISH BREAKOUT" : "—"
    phaseClr = inQuiet ? gr :
               dailyBias == 0 ? yl :
               dailyBias == 1 ? gn : rd
    table.cell(d, 0, 1, "Phase", text_color=wh, text_size=size.small)
    table.cell(d, 1, 1, phaseStr, text_color=phaseClr, text_size=size.small)

    // Range
    rangeStr = rangeLocked ? str.tostring(rangeHigh, "#.##") + " / " + str.tostring(rangeLow, "#.##") :
               inQuiet ? "Building..." : "—"
    table.cell(d, 0, 2, "Range", text_color=wh, text_size=size.small)
    table.cell(d, 1, 2, rangeStr, text_color=rangeLocked ? wh : gr, text_size=size.small)

    // Range size
    sizeStr = rangeLocked ? "$" + str.tostring(rangeHigh - rangeLow, "#.##") : "—"
    table.cell(d, 0, 3, "Size", text_color=wh, text_size=size.small)
    table.cell(d, 1, 3, sizeStr, text_color=wh, text_size=size.small)

    // Breakout level
    bkStr = not na(breakoutLevel) ? str.tostring(breakoutLevel, "#.##") : "None yet"
    table.cell(d, 0, 4, "Breakout", text_color=wh, text_size=size.small)
    table.cell(d, 1, 4, bkStr, text_color=dailyBias == 1 ? gn : dailyBias == -1 ? rd : gr, text_size=size.small)

    // Entries today
    table.cell(d, 0, 5, "Entries", text_color=wh, text_size=size.small)
    table.cell(d, 1, 5, str.tostring(dailyEntryCount) + " / " + str.tostring(maxEntries),
         text_color=wh, text_size=size.small)

    // Action
    actionStr = inQuiet ? "Wait for range to lock" :
                dailyBias == 0 and rangeLocked ? "Watch for breakout above " + str.tostring(rangeHigh, "#.#") + " or below " + str.tostring(rangeLow, "#.#") :
                dailyBias == 1 and dailyEntryCount < maxEntries ? "Buy pullback to " + str.tostring(breakoutLevel, "#.#") :
                dailyBias == -1 and dailyEntryCount < maxEntries ? "Sell pullback to " + str.tostring(breakoutLevel, "#.#") :
                "Done for today"
    table.cell(d, 0, 6, "ACTION", text_color=yl, text_size=size.normal, bgcolor=color.new(color.black, 0))
    table.cell(d, 1, 6, actionStr, text_color=wh, text_size=size.small, bgcolor=color.new(color.black, 0))

// ────────────────────────────────────────────────────────────
// ALERTS
// ────────────────────────────────────────────────────────────

alertcondition(bullBreakout, "Bullish Breakout", "Gold Pulse: Bullish breakout above quiet range — watch for pullback to buy")
alertcondition(bearBreakout, "Bearish Breakout", "Gold Pulse: Bearish breakout below quiet range — watch for pullback to sell")
alertcondition(bullSignal,   "Buy Entry",        "Gold Pulse: BUY — pullback to breakout level, candle confirmed")
alertcondition(bearSignal,   "Sell Entry",       "Gold Pulse: SELL — pullback to breakout level, candle confirmed")

// ============================================================
// HOW TO TRADE GOLD PULSE
// ============================================================
//
// DAILY ROUTINE:
//
// 1. QUIET PHASE (dark background)
//    The range is building. Do nothing. Wait for it to lock.
//    Dashboard shows: "Wait for range to lock"
//
// 2. BREAKOUT (green/red arrow)
//    Price closes above the range high → BULLISH day.
//    Price closes below the range low  → BEARISH day.
//    Green arrow = bullish breakout. Red arrow = bearish breakout.
//    The pullback zone (shaded box) appears around the breakout level.
//    Dashboard shows: "Watch for breakout above/below XXXX"
//
// 3. PULLBACK (price returns to the shaded zone)
//    Price pulls back toward the breakout level.
//    When a confirming candle forms in the zone:
//    "BUY" or "SELL" triangle appears with SL and TP labels.
//    Dashboard shows: "Buy pullback to XXXX" or "Sell pullback to XXXX"
//
// 4. MANAGE THE TRADE
//    Stop loss: range midpoint (if it breaks the midpoint, the breakout failed)
//    Take profit: 1.5x the risk distance (adjustable in settings)
//    Max 2 entries per day (adjustable)
//
// WHAT MAKES THIS DIFFERENT:
//
// - No lagging indicators. Only price structure.
// - The breakout direction IS the trend. No separate trend filter.
// - The pullback IS the entry. No separate displacement detection.
// - The range midpoint IS the stop. No arbitrary ATR-based stops.
// - One setup per day. Clean, simple, repeatable.
//
// WHY IT WORKS ON GOLD:
//
// Gold establishes a quiet range during low-volatility hours.
// When Tokyo/London bring volume, the range breaks.
// On gold, breakouts CONTINUE (proven across 8 iterations of testing).
// The pullback to the breakout level is institutional reloading —
// they break it, pull back to fill at a better price, then push again.
// You enter where they reload.
//
// RISK MANAGEMENT:
//
// - Risk 0.5% per trade (scalping frequency requires tight risk)
// - Max 2 entries per day
// - If the range is >$40, skip the day (too volatile, levels unreliable)
// - If no breakout by London close, skip the day
// - Never move your stop. If it hits, the setup was wrong.
// ============================================================
