// ============================================================
// XAUUSD Scalp v4 — Data-Driven Oversold Dip Buy
// ============================================================
// Built from statistical analysis of 4,420 bars of 15m gold data.
// The ONLY pattern with a real edge:
//   Price >1% below 20-SMA → Buy → Hold 1-2 bars → Exit
//   58.7% win rate across 254 occurrences
//
// v1: VWAP wick touch → 0% win rate
// v2: VWAP confirmed retrace → 19% win rate
// v3: EMA crossover trend-following → 31.5% win rate
// v4: Data-proven oversold dip buy → test now
// ============================================================

//@version=5
strategy("XAUUSD Scalp v4",
     overlay            = true,
     initial_capital    = 10000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 15,
     commission_type    = strategy.commission.cash_per_order,
     commission_value   = 3.5,
     slippage           = 3,
     pyramiding         = 0,
     process_orders_on_close = false,
     calc_on_every_tick = false)

// ────────────────────────────────────────────────────────────
// INPUTS
// ────────────────────────────────────────────────────────────

smaLen       = input.int(20,    "SMA Length",              minval=10, maxval=50,  group="Signal")
dipPct       = input.float(1.0, "Dip % Below SMA",        minval=0.3, maxval=3.0, group="Signal", step=0.1,
     tooltip="How far below the 20-SMA price must dip to trigger. Data showed >1% has 58.7% win rate.")

rsiLen       = input.int(14,    "RSI Length",              minval=5,  maxval=30,  group="Signal")
rsiThresh    = input.int(30,    "RSI Oversold Threshold",  minval=15, maxval=45,  group="Signal",
     tooltip="RSI<25 had 55.7% win rate. Set slightly higher for more signals.")

holdBars     = input.int(2,     "Hold Duration (bars)",    minval=1,  maxval=8,   group="Exit",
     tooltip="1 bar=15min, 2 bars=30min. Data showed edge on 1-2 bar hold.")

useFixedStop = input.bool(true, "Use Fixed Stop Loss",                             group="Exit")
atrLen       = input.int(14,    "ATR Length",              minval=5,  maxval=30,  group="Exit")
atrStopMult  = input.float(1.5, "ATR Stop Multiplier",    minval=0.5, maxval=4.0, group="Exit", step=0.1)

maxPerDay    = input.int(8,     "Max Trades Per Day",      minval=1,  maxval=20,  group="Strategy")
closeAtEOD   = input.bool(true, "Close at End of Day",                             group="Strategy")

asianSess    = input.session("2000-0200", "Asian Session",    group="Sessions")
londonSess   = input.session("0300-0800", "London Session",   group="Sessions")
nySess       = input.session("0830-1500", "New York Session", group="Sessions")
showSessions = input.bool(true, "Show Session Background",    group="Sessions")

// ────────────────────────────────────────────────────────────
// SESSIONS
// ────────────────────────────────────────────────────────────

inAsian  = not na(time(timeframe.period, asianSess))
inLondon = not na(time(timeframe.period, londonSess))
inNY     = not na(time(timeframe.period, nySess))

bgcolor(showSessions and inAsian  ? color.new(color.gray,   93) : na, title="Asian")
bgcolor(showSessions and inLondon ? color.new(color.blue,   93) : na, title="London")
bgcolor(showSessions and inNY     ? color.new(color.orange, 93) : na, title="NY")

// ────────────────────────────────────────────────────────────
// INDICATORS
// ────────────────────────────────────────────────────────────

sma20    = ta.sma(close, smaLen)
rsiValue = ta.rsi(close, rsiLen)
atrValue = ta.atr(atrLen)

plot(sma20, "SMA 20", color=color.new(color.yellow, 20), linewidth=2)

// Distance from SMA as percentage
distPct = (close - sma20) / sma20 * 100

// ────────────────────────────────────────────────────────────
// OVERSOLD ZONE VISUALIZATION
// ────────────────────────────────────────────────────────────

oversoldLevel = sma20 * (1 - dipPct / 100)
plot(oversoldLevel, "Oversold Level", color=color.new(color.green, 40), style=plot.style_stepline, linewidth=1)

// Fill between SMA and oversold level
smaPlot = plot(sma20, "SMA fill", color=na, display=display.none)
osPlot  = plot(oversoldLevel, "OS fill", color=na, display=display.none)
fill(smaPlot, osPlot, color=color.new(color.green, 90), title="Dip Zone")

// ────────────────────────────────────────────────────────────
// SIGNAL: BUY THE DIP (LONG ONLY)
// ────────────────────────────────────────────────────────────

// Core signal: price dipped below threshold AND RSI confirms oversold
oversoldDip = distPct < -dipPct
rsiOversold = rsiValue < rsiThresh

// Trade counter
isNewDay = ta.change(time("D")) != 0
var int dailyCount = 0
if isNewDay
    dailyCount := 0

// Combined buy signal
buySignal = oversoldDip and
     rsiOversold and
     dailyCount < maxPerDay and
     strategy.position_size == 0

// ────────────────────────────────────────────────────────────
// EXECUTION
// ────────────────────────────────────────────────────────────

var float entryStop = na

if buySignal
    entryStop := useFixedStop ? close - atrValue * atrStopMult : na
    strategy.entry("Dip Buy", strategy.long)
    if useFixedStop
        strategy.exit("Stop", "Dip Buy", stop=entryStop)
    dailyCount += 1

// ────────────────────────────────────────────────────────────
// TIME-BASED EXIT (hold for N bars then close)
// ────────────────────────────────────────────────────────────

barsSinceEntry = strategy.position_size > 0 ? bar_index - strategy.opentrades.entry_bar_index(0) : 0

if strategy.position_size > 0 and barsSinceEntry >= holdBars
    strategy.close("Dip Buy", comment="Time Exit")

// ────────────────────────────────────────────────────────────
// END OF DAY FLATTEN
// ────────────────────────────────────────────────────────────

endOfDay = not na(time(timeframe.period, "1455-1500"))
if closeAtEOD and endOfDay and strategy.position_size > 0
    strategy.close_all(comment="EOD")

// ────────────────────────────────────────────────────────────
// SIGNAL MARKER
// ────────────────────────────────────────────────────────────

plotshape(buySignal, "Buy Dip", shape.triangleup, location.belowbar, color.green, size=size.small)

// ────────────────────────────────────────────────────────────
// DASHBOARD
// ────────────────────────────────────────────────────────────

if barstate.islast
    var table d = table.new(position.top_right, 2, 6,
         bgcolor=color.new(color.black, 15),
         border_color=color.new(color.gray, 50), border_width=1,
         frame_color=color.new(color.gray, 30), frame_width=2)

    gn = color.green
    rd = color.red
    gr = color.gray

    table.cell(d, 0, 0, "XAUUSD v4", text_color=color.yellow, text_size=size.normal, bgcolor=color.new(color.black,0))
    table.cell(d, 1, 0, "DIP BUY",   text_color=color.yellow, text_size=size.normal, bgcolor=color.new(color.black,0))

    // Distance from SMA
    distStr = str.tostring(distPct, "#.##") + "%"
    distClr = distPct < -dipPct ? gn : distPct > dipPct ? rd : gr
    table.cell(d, 0, 1, "Dist from SMA", text_color=color.white, text_size=size.small)
    table.cell(d, 1, 1, distStr,          text_color=distClr,     text_size=size.small)

    // RSI
    rsiClr = rsiValue < rsiThresh ? gn : rsiValue > 70 ? rd : gr
    table.cell(d, 0, 2, "RSI",       text_color=color.white, text_size=size.small)
    table.cell(d, 1, 2, str.tostring(rsiValue, "#.#"), text_color=rsiClr, text_size=size.small)

    // Session
    sess = inLondon ? "LONDON" : inNY ? "NY" : inAsian ? "ASIAN" : "OFF"
    table.cell(d, 0, 3, "Session", text_color=color.white, text_size=size.small)
    table.cell(d, 1, 3, sess,     text_color=inLondon ? color.blue : inNY ? color.orange : gr, text_size=size.small)

    // Trades today
    table.cell(d, 0, 4, "Trades Today", text_color=color.white, text_size=size.small)
    table.cell(d, 1, 4, str.tostring(dailyCount) + " / " + str.tostring(maxPerDay),
         text_color=color.white, text_size=size.small)

    // Verdict
    vStr = oversoldDip and rsiOversold ? "DIP — BUY ZONE" : "WAIT FOR DIP"
    vClr = oversoldDip and rsiOversold ? gn : gr
    table.cell(d, 0, 5, "VERDICT", text_color=color.yellow, text_size=size.normal, bgcolor=color.new(color.black,0))
    table.cell(d, 1, 5, vStr,     text_color=vClr,          text_size=size.normal, bgcolor=color.new(color.black,0))
