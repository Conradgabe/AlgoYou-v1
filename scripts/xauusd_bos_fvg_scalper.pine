// ============================================================
// BOS + FVG Scalper v2
// ============================================================
// Upgrade from v1:
//   1. Higher Timeframe Alignment (1H EMA trend filter)
//   2. Premium/Discount Zones (buy low, sell high)
//   3. Displacement Quality Filter (strong BOS only)
//   4. Multi-pair ready (works on any pair)
//   5. FVG size filter + stack limit + rejection (from v1)
//
// Best tested pairs: NZD/USD, GBP/USD, USD/JPY, CAD/JPY, XAUUSD
// Timeframe: 5m (primary), also works on 3m and 1m
// ============================================================

//@version=5
indicator("BOS+FVG Scalper v2", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=200)

// ────────────────────────────────────────────────────────────
// INPUTS
// ────────────────────────────────────────────────────────────

// Structure
swingLen   = input.int(5, "Swing Lookback", minval=2, maxval=8, group="Structure")

// HTF Filter (Upgrade 1)
useHTFFilter  = input.bool(true,  "Enable HTF Trend Filter", group="HTF Filter",
     tooltip="Only allow BUY when 1H is bullish, SELL when 1H is bearish.")
htfTimeframe  = input.string("60", "HTF Timeframe", options=["15", "30", "60", "120", "240"], group="HTF Filter")
htfEmaLen     = input.int(50, "HTF EMA Length", minval=10, maxval=200, group="HTF Filter")

// Premium/Discount (Upgrade 2)
usePDZones = input.bool(false, "Enable Premium/Discount Filter", group="Premium/Discount",
     tooltip="BUY only in discount (below midpoint), SELL only in premium (above midpoint). OFF by default — can conflict with HTF filter in trends.")
pdLookback = input.int(100, "Range Lookback (bars)", minval=20, maxval=500, group="Premium/Discount")
showPDLine = input.bool(true, "Show Equilibrium Line", group="Premium/Discount")

// FVG
fvgMaxBars      = input.int(5,    "FVG Search Window (bars from BOS)", minval=2, maxval=10, group="FVG")
fvgMaxAge       = input.int(50,   "FVG Max Age (bars)",       minval=10, maxval=200, group="FVG")
fvgMitigate     = input.bool(true, "Remove Mitigated FVGs",   group="FVG")
fvgMinSizeATR   = input.float(0.3, "Min FVG Size (x ATR)",    minval=0.1, maxval=2.0, step=0.1, group="FVG")
fvgStackLimit   = input.int(2,    "Max Tradeable FVGs per Direction", minval=1, maxval=5, group="FVG")
useDispQuality  = input.bool(true, "Require Strong BOS Candle", group="FVG",
     tooltip="Only create FVGs when the BOS move was driven by a large candle.")
dispQualityMult = input.float(1.2, "BOS Candle Body (x avg)", minval=1.0, maxval=4.0, step=0.1, group="FVG",
     tooltip="BOS candle body must be this many times the average. 1.2 = 20% above average (moderate filter).")

// Entry
maxRetestBars    = input.int(40, "Max Bars to Wait for Retest", minval=5, maxval=100, group="Entry")
oneEntryPerFVG   = input.bool(true, "One Entry Per FVG",       group="Entry")
requireRejection = input.bool(true, "Require Rejection Candle", group="Entry",
     tooltip="Signal requires candle to close in trade direction with wick rejection at FVG level.")
cooldownBars     = input.int(6,  "Cooldown Between Signals (bars)", minval=3, maxval=20, group="Entry")

// Risk
rrRatio      = input.float(2.0, "Reward:Risk Ratio", minval=1.0, maxval=5.0, step=0.5, group="Risk")
showRRLabel  = input.bool(true, "Show R:R Label",    group="Risk")
showRTargets = input.bool(true, "Show 1R/2R/3R Levels", group="Risk")
exitBars     = input.int(4, "Exit Zone (bars)",       minval=2, maxval=12, group="Risk")

// Time filter
useTimeFilter = input.bool(true, "Filter by Hour",    group="Time")
blockHours    = input.string("2,11,17,22", "Blocked Hours (UTC)", group="Time")
highlightSB   = input.bool(true, "Highlight Silver Bullet", group="Time")

// Display
showSwings    = input.bool(false, "Show Swing Points",      group="Display")
showBOS       = input.bool(false, "Show BOS Labels",        group="Display")
showFVGBoxes  = input.bool(true,  "Show FVG Boxes",         group="Display")
showEntries   = input.bool(true,  "Show Entry Signals",     group="Display")
showSLTP      = input.bool(false, "Show SL/TP Labels",      group="Display")
showExitZone  = input.bool(false, "Show Exit Zone Line",    group="Display")
showPosBox    = input.bool(false, "Show Position Box",      group="Display")
showDashboard = input.bool(true,  "Show Dashboard",         group="Display")
maxSignalsDay = input.int(6, "Max Signals Per Day", minval=1, maxval=20, group="Display")
posBoxWidth   = input.int(20, "Position Box Width (bars)", minval=5, maxval=50, group="Risk")

// ────────────────────────────────────────────────────────────
// TIME FILTER
// ────────────────────────────────────────────────────────────

currentHour = hour(time, "UTC")

isBlockedHour = false
if useTimeFilter
    blockedArr = str.split(blockHours, ",")
    for i = 0 to array.size(blockedArr) - 1
        h = str.tonumber(array.get(blockedArr, i))
        if not na(h) and currentHour == h
            isBlockedHour := true

isSilverBullet = currentHour == 7 or currentHour == 14 or currentHour == 18

bgcolor(highlightSB and currentHour == 14 ? color.new(#ffd700, 92) : na, title="NY AM SB")
bgcolor(highlightSB and currentHour == 7  ? color.new(#87ceeb, 92) : na, title="London SB")
bgcolor(highlightSB and currentHour == 18 ? color.new(#dda0dd, 92) : na, title="NY PM SB")

// ────────────────────────────────────────────────────────────
// UPGRADE 1: HIGHER TIMEFRAME ALIGNMENT
// ────────────────────────────────────────────────────────────

htfEma      = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, htfEmaLen), lookahead=barmerge.lookahead_off)
htfClose    = request.security(syminfo.tickerid, htfTimeframe, close, lookahead=barmerge.lookahead_off)
htfBullish  = htfClose > htfEma
htfBearish  = htfClose < htfEma

htfAllowBuy  = useHTFFilter ? htfBullish : true
htfAllowSell = useHTFFilter ? htfBearish : true

// ────────────────────────────────────────────────────────────
// SWING DETECTION
// ────────────────────────────────────────────────────────────

swingHighVal = ta.pivothigh(high, swingLen, swingLen)
swingLowVal  = ta.pivotlow(low, swingLen, swingLen)

isSwingHigh = not na(swingHighVal)
isSwingLow  = not na(swingLowVal)

var float lastSH     = na
var int   lastSH_bar = na
var float lastSL     = na
var int   lastSL_bar = na

if isSwingHigh
    lastSH     := swingHighVal
    lastSH_bar := bar_index - swingLen
if isSwingLow
    lastSL     := swingLowVal
    lastSL_bar := bar_index - swingLen

plotshape(showSwings and isSwingHigh, "SH", shape.triangledown, location.abovebar,
     color=color.new(#ef5350, 40), offset=-swingLen, size=size.tiny)
plotshape(showSwings and isSwingLow, "SL", shape.triangleup, location.belowbar,
     color=color.new(#66bb6a, 40), offset=-swingLen, size=size.tiny)

// ────────────────────────────────────────────────────────────
// UPGRADE 2: PREMIUM / DISCOUNT ZONES
// ────────────────────────────────────────────────────────────

rangeHigh = ta.highest(high, pdLookback)
rangeLow  = ta.lowest(low, pdLookback)
rangeMid  = (rangeHigh + rangeLow) / 2

inDiscount = close < rangeMid
inPremium  = close > rangeMid

pdAllowBuy  = usePDZones ? inDiscount : true
pdAllowSell = usePDZones ? inPremium  : true

plot(showPDLine ? rangeMid : na, "Equilibrium", color=color.new(#ffeb3b, 50), style=plot.style_stepline, linewidth=1)

// ────────────────────────────────────────────────────────────
// BREAK OF STRUCTURE (BOS)
// ────────────────────────────────────────────────────────────

bullBOS = not na(lastSH) and close > lastSH and close[1] <= lastSH
bearBOS = not na(lastSL) and close < lastSL and close[1] >= lastSL

var int   bosDir   = 0
var float bosLevel = na
var int   bosBar   = na
var float bosBody  = na    // Upgrade 3: track BOS candle body size

if bullBOS
    bosDir   := 1
    bosLevel := lastSH
    bosBar   := bar_index
    bosBody  := math.abs(close - open)

if bearBOS
    bosDir   := -1
    bosLevel := lastSL
    bosBar   := bar_index
    bosBody  := math.abs(close - open)

if showBOS and bullBOS
    label.new(bar_index, low - (high - low) * 0.3, "BOS",
         style=label.style_label_up, color=color.new(#2196F3, 20),
         textcolor=color.white, size=size.tiny)
    line.new(lastSH_bar, lastSH, bar_index, lastSH,
         color=color.new(#2196F3, 40), style=line.style_dashed, width=1)

if showBOS and bearBOS
    label.new(bar_index, high + (high - low) * 0.3, "BOS",
         style=label.style_label_down, color=color.new(#2196F3, 20),
         textcolor=color.white, size=size.tiny)
    line.new(lastSL_bar, lastSL, bar_index, lastSL,
         color=color.new(#2196F3, 40), style=line.style_dashed, width=1)

// ────────────────────────────────────────────────────────────
// FVG DETECTION (with size filter + displacement quality)
// ────────────────────────────────────────────────────────────

fvgATR     = ta.atr(14)
fvgMinSize = fvgATR * fvgMinSizeATR
avgBody    = ta.sma(math.abs(close - open), 20)

// Upgrade 3: Displacement quality — was the BOS candle strong?
strongBOS = useDispQuality ? (not na(bosBody) and bosBody > avgBody * dispQualityMult) : true

// Raw FVG detection
rawBullFVG  = low > high[2] and close[1] > open[1]
bullFVGsize = rawBullFVG ? low - high[2] : 0.0
rawBearFVG  = high < low[2] and close[1] < open[1]
bearFVGsize = rawBearFVG ? low[2] - high : 0.0

// Combined filter: near BOS + right direction + min size + strong displacement
barsSinceBOS = not na(bosBar) ? bar_index - bosBar : 999
nearBOS      = barsSinceBOS <= fvgMaxBars

bullFVG = rawBullFVG and nearBOS and bosDir == 1 and bullFVGsize >= fvgMinSize and strongBOS
bearFVG = rawBearFVG and nearBOS and bosDir == -1 and bearFVGsize >= fvgMinSize and strongBOS

// FVG tracking arrays
var float[] fvgTop      = array.new_float()
var float[] fvgBottom   = array.new_float()
var int[]   fvgBar      = array.new_int()
var int[]   fvgDir      = array.new_int()
var bool[]  fvgRetested = array.new_bool()
var box[]   fvgBoxes    = array.new_box()

if bullFVG
    fTop = low
    fBot = high[2]
    array.push(fvgTop, fTop)
    array.push(fvgBottom, fBot)
    array.push(fvgBar, bar_index)
    array.push(fvgDir, 1)
    array.push(fvgRetested, false)
    if showFVGBoxes
        array.push(fvgBoxes, box.new(bar_index - 1, fTop, bar_index + fvgMaxAge, fBot,
             border_color=color.new(#66bb6a, 50), bgcolor=color.new(#66bb6a, 88)))
    else
        array.push(fvgBoxes, box(na))

if bearFVG
    fTop = low[2]
    fBot = high
    array.push(fvgTop, fTop)
    array.push(fvgBottom, fBot)
    array.push(fvgBar, bar_index)
    array.push(fvgDir, -1)
    array.push(fvgRetested, false)
    if showFVGBoxes
        array.push(fvgBoxes, box.new(bar_index - 1, fTop, bar_index + fvgMaxAge, fBot,
             border_color=color.new(#ef5350, 50), bgcolor=color.new(#ef5350, 88)))
    else
        array.push(fvgBoxes, box(na))

// ────────────────────────────────────────────────────────────
// FVG RETEST = ENTRY SIGNAL
// ────────────────────────────────────────────────────────────

isNewDay = ta.change(time("D")) != 0
var int dailySignals = 0
if isNewDay
    dailySignals := 0

var bool  buySignal   = false
var bool  sellSignal  = false
var float entryPrice  = na
var float stopPrice   = na
var float targetPrice = na
var bool  entrySB     = false
var int   lastBuyBar  = na
var int   lastSellBar = na

buySignal  := false
sellSignal := false
entrySB    := false

// Stack counting
bullFVGcount = 0
bearFVGcount = 0
if array.size(fvgDir) > 0
    for i = 0 to array.size(fvgDir) - 1
        if array.get(fvgDir, i) == 1
            bullFVGcount += 1
        if array.get(fvgDir, i) == -1
            bearFVGcount += 1

// Rejection candle detection
candleUpperHalf = close > (high + low) / 2
candleLowerHalf = close < (high + low) / 2
buyRejection  = close > open and candleUpperHalf
sellRejection = close < open and candleLowerHalf

// Iterate FVGs newest-first
if array.size(fvgTop) > 0
    bullIdx = 0
    bearIdx = 0

    for i = array.size(fvgTop) - 1 to 0
        if i >= array.size(fvgTop)
            continue

        fTop    = array.get(fvgTop, i)
        fBot    = array.get(fvgBottom, i)
        fBarIdx = array.get(fvgBar, i)
        fDir    = array.get(fvgDir, i)
        fUsed   = array.get(fvgRetested, i)
        fAge    = bar_index - fBarIdx
        fMid    = (fTop + fBot) / 2

        // Remove expired or mitigated
        expired   = fAge > fvgMaxAge
        mitigated = false
        if fvgMitigate
            if fDir == 1 and close < fBot
                mitigated := true
            if fDir == -1 and close > fTop
                mitigated := true

        if expired or mitigated
            bx = array.get(fvgBoxes, i)
            if not na(bx)
                box.delete(bx)
            array.remove(fvgTop, i)
            array.remove(fvgBottom, i)
            array.remove(fvgBar, i)
            array.remove(fvgDir, i)
            array.remove(fvgRetested, i)
            array.remove(fvgBoxes, i)
            continue

        // Stack limit
        isTradeable = false
        if fDir == 1
            bullIdx += 1
            isTradeable := bullIdx <= fvgStackLimit
        if fDir == -1
            bearIdx += 1
            isTradeable := bearIdx <= fvgStackLimit
        if not isTradeable
            continue

        if fUsed and oneEntryPerFVG
            continue
        if fAge > maxRetestBars or fAge < 1
            continue
        if isBlockedHour
            continue
        if dailySignals >= maxSignalsDay
            continue

        // Cooldown
        recentSell = not na(lastSellBar) and (bar_index - lastSellBar) <= cooldownBars
        recentBuy  = not na(lastBuyBar) and (bar_index - lastBuyBar) <= cooldownBars

        // ── BUY ENTRY ──
        bullTouch     = fDir == 1 and low <= fTop and close > fBot
        bullConfirmed = requireRejection ? (bullTouch and buyRejection) : bullTouch

        if bullConfirmed and not buySignal and not recentSell and not recentBuy and
             htfAllowBuy and pdAllowBuy
            buySignal    := true
            entryPrice   := fMid
            stopPrice    := fBot - (fTop - fBot) * 0.5
            targetPrice  := fMid + (fMid - stopPrice) * rrRatio
            entrySB      := isSilverBullet
            array.set(fvgRetested, i, true)
            dailySignals += 1
            lastBuyBar   := bar_index
            bx = array.get(fvgBoxes, i)
            if not na(bx)
                box.set_border_color(bx, color.new(#00e676, 0))
                box.set_bgcolor(bx, color.new(#00e676, 75))

        // ── SELL ENTRY ──
        bearTouch     = fDir == -1 and high >= fBot and close < fTop
        bearConfirmed = requireRejection ? (bearTouch and sellRejection) : bearTouch

        if bearConfirmed and not sellSignal and not recentBuy and not recentSell and
             htfAllowSell and pdAllowSell
            sellSignal   := true
            entryPrice   := fMid
            stopPrice    := fTop + (fTop - fBot) * 0.5
            targetPrice  := fMid - (stopPrice - fMid) * rrRatio
            entrySB      := isSilverBullet
            array.set(fvgRetested, i, true)
            dailySignals += 1
            lastSellBar  := bar_index
            bx = array.get(fvgBoxes, i)
            if not na(bx)
                box.set_border_color(bx, color.new(#ff1744, 0))
                box.set_bgcolor(bx, color.new(#ff1744, 75))

// ────────────────────────────────────────────────────────────
// VISUAL: ENTRY SIGNALS
// ────────────────────────────────────────────────────────────

plotshape(showEntries and buySignal, "Buy", shape.triangleup, location.belowbar,
     color=entrySB and buySignal ? color.new(#ffd700, 0) : color.new(#00e676, 0),
     size=size.small, text="", textcolor=color.white)

if buySignal and showEntries
    label.new(bar_index, low - (high - low) * 0.5, entrySB ? "BUY *" : "BUY",
         style=label.style_label_up,
         color=entrySB ? color.new(#ffd700, 0) : color.new(#00e676, 0),
         textcolor=color.white, size=size.small)

plotshape(showEntries and sellSignal, "Sell", shape.triangledown, location.abovebar,
     color=entrySB and sellSignal ? color.new(#ffd700, 0) : color.new(#ff1744, 0),
     size=size.small, text="", textcolor=color.white)

if sellSignal and showEntries
    label.new(bar_index, high + (high - low) * 0.5, entrySB ? "SELL *" : "SELL",
         style=label.style_label_down,
         color=entrySB ? color.new(#ffd700, 0) : color.new(#ff1744, 0),
         textcolor=color.white, size=size.small)

// SL/TP labels
if buySignal and showSLTP
    label.new(bar_index, stopPrice, "SL", style=label.style_label_up, color=color.new(#ff5252, 20), textcolor=color.white, size=size.tiny)
    label.new(bar_index, targetPrice, "TP", style=label.style_label_down, color=color.new(#4caf50, 20), textcolor=color.white, size=size.tiny)
if sellSignal and showSLTP
    label.new(bar_index, stopPrice, "SL", style=label.style_label_down, color=color.new(#ff5252, 20), textcolor=color.white, size=size.tiny)
    label.new(bar_index, targetPrice, "TP", style=label.style_label_up, color=color.new(#4caf50, 20), textcolor=color.white, size=size.tiny)

// Exit zone
if (buySignal or sellSignal) and showExitZone
    line.new(bar_index + exitBars, high + (high - low), bar_index + exitBars, low - (high - low),
         color=color.new(color.yellow, 40), style=line.style_dotted, width=1)

// Position box
if buySignal and showPosBox
    risk = entryPrice - stopPrice
    box.new(bar_index, targetPrice, bar_index + posBoxWidth, entryPrice, border_color=color.new(#4caf50, 40), bgcolor=color.new(#4caf50, 80))
    box.new(bar_index, entryPrice, bar_index + posBoxWidth, stopPrice, border_color=color.new(#ff5252, 40), bgcolor=color.new(#ff5252, 80))
    line.new(bar_index, entryPrice, bar_index + posBoxWidth, entryPrice, color=color.new(color.white, 30), width=1)
    if showRRLabel
        label.new(bar_index + posBoxWidth, targetPrice, str.tostring(rrRatio, "#.#") + "R", style=label.style_label_left, color=color.new(#4caf50, 20), textcolor=color.white, size=size.tiny)
    if showRTargets
        for r = 1 to 3
            line.new(bar_index, entryPrice + risk * r, bar_index + posBoxWidth + 2, entryPrice + risk * r,
                 color=r == 1 ? color.new(#66bb6a, 50) : r == 2 ? color.new(#4caf50, 40) : color.new(#2e7d32, 30), width=1, style=line.style_dotted)

if sellSignal and showPosBox
    risk = stopPrice - entryPrice
    box.new(bar_index, entryPrice, bar_index + posBoxWidth, targetPrice, border_color=color.new(#4caf50, 40), bgcolor=color.new(#4caf50, 80))
    box.new(bar_index, stopPrice, bar_index + posBoxWidth, entryPrice, border_color=color.new(#ff5252, 40), bgcolor=color.new(#ff5252, 80))
    line.new(bar_index, entryPrice, bar_index + posBoxWidth, entryPrice, color=color.new(color.white, 30), width=1)
    if showRRLabel
        label.new(bar_index + posBoxWidth, targetPrice, str.tostring(rrRatio, "#.#") + "R", style=label.style_label_left, color=color.new(#4caf50, 20), textcolor=color.white, size=size.tiny)
    if showRTargets
        for r = 1 to 3
            line.new(bar_index, entryPrice - risk * r, bar_index + posBoxWidth + 2, entryPrice - risk * r,
                 color=r == 1 ? color.new(#66bb6a, 50) : r == 2 ? color.new(#4caf50, 40) : color.new(#2e7d32, 30), width=1, style=line.style_dotted)

barcolor(buySignal ? color.new(#00e676, 0) : na, title="Buy Bar")
barcolor(sellSignal ? color.new(#ff1744, 0) : na, title="Sell Bar")

// ────────────────────────────────────────────────────────────
// DASHBOARD
// ────────────────────────────────────────────────────────────

if showDashboard and barstate.islast
    var table d = table.new(position.top_right, 2, 10,
         bgcolor=color.new(color.black, 10),
         border_color=color.new(color.gray, 50), border_width=1,
         frame_color=color.new(color.gray, 30), frame_width=2)

    gn = #00e676
    rd = #ff1744
    yl = #ffd700
    wh = color.white
    gr = color.gray

    table.cell(d, 0, 0, syminfo.ticker, text_color=yl, text_size=size.normal, bgcolor=color.new(color.black, 0))
    table.cell(d, 1, 0, "BOS+FVG v2", text_color=yl, text_size=size.normal, bgcolor=color.new(color.black, 0))

    // Hour
    sbStr = isSilverBullet ? " * SB" : (isBlockedHour ? " BLOCKED" : "")
    sbClr = isSilverBullet ? yl : (isBlockedHour ? rd : gr)
    table.cell(d, 0, 1, "Hour", text_color=wh, text_size=size.small)
    table.cell(d, 1, 1, str.tostring(currentHour) + ":00 UTC" + sbStr, text_color=sbClr, text_size=size.small)

    // HTF Bias (Upgrade 1)
    htfStr = htfBullish ? "BULLISH" : htfBearish ? "BEARISH" : "NEUTRAL"
    htfClr = htfBullish ? gn : htfBearish ? rd : gr
    table.cell(d, 0, 2, htfTimeframe + "m Bias", text_color=wh, text_size=size.small)
    table.cell(d, 1, 2, htfStr, text_color=htfClr, text_size=size.small)

    // Premium/Discount (Upgrade 2)
    pdStr = inDiscount ? "DISCOUNT" : inPremium ? "PREMIUM" : "EQUILIBRIUM"
    pdClr = inDiscount ? gn : inPremium ? rd : gr
    table.cell(d, 0, 3, "Zone", text_color=wh, text_size=size.small)
    table.cell(d, 1, 3, pdStr, text_color=pdClr, text_size=size.small)

    // BOS direction
    bosStr = bosDir == 1 ? "BULLISH" : bosDir == -1 ? "BEARISH" : "NONE"
    bosClr = bosDir == 1 ? gn : bosDir == -1 ? rd : gr
    table.cell(d, 0, 4, "Last BOS", text_color=wh, text_size=size.small)
    table.cell(d, 1, 4, bosStr, text_color=bosClr, text_size=size.small)

    // Active FVGs
    table.cell(d, 0, 5, "Active FVGs", text_color=wh, text_size=size.small)
    table.cell(d, 1, 5, str.tostring(array.size(fvgTop)), text_color=wh, text_size=size.small)

    // Nearest FVG
    nearestFVG = "None"
    nearestClr = gr
    if array.size(fvgTop) > 0
        closestDist = 99999.0
        for i = 0 to array.size(fvgTop) - 1
            if not array.get(fvgRetested, i)
                fMid = (array.get(fvgTop, i) + array.get(fvgBottom, i)) / 2
                dist = math.abs(close - fMid)
                if dist < closestDist
                    closestDist := dist
                    fDir2 = array.get(fvgDir, i)
                    nearestFVG := (fDir2 == 1 ? "BULL " : "BEAR ") +
                         str.tostring(array.get(fvgTop, i), "#.#") + "-" +
                         str.tostring(array.get(fvgBottom, i), "#.#")
                    nearestClr := fDir2 == 1 ? gn : rd
    table.cell(d, 0, 6, "Nearest FVG", text_color=wh, text_size=size.small)
    table.cell(d, 1, 6, nearestFVG, text_color=nearestClr, text_size=size.small)

    // Signals today
    table.cell(d, 0, 7, "Signals", text_color=wh, text_size=size.small)
    table.cell(d, 1, 7, str.tostring(dailySignals) + "/" + str.tostring(maxSignalsDay), text_color=wh, text_size=size.small)

    // Swing levels
    table.cell(d, 0, 8, "Swing H/L", text_color=wh, text_size=size.small)
    table.cell(d, 1, 8, (not na(lastSH) ? str.tostring(lastSH, "#.#") : "-") + " / " +
         (not na(lastSL) ? str.tostring(lastSL, "#.#") : "-"), text_color=wh, text_size=size.small)

    // Action
    actionStr = isBlockedHour ? "Blocked hour" :
         not htfAllowBuy and not htfAllowSell ? "HTF unclear" :
         bosDir == 1 and htfAllowBuy and pdAllowBuy and array.size(fvgTop) > 0 ? "BUY setup active" :
         bosDir == -1 and htfAllowSell and pdAllowSell and array.size(fvgTop) > 0 ? "SELL setup active" :
         bosDir == 1 and not htfAllowBuy ? "Bullish BOS but HTF bearish - wait" :
         bosDir == -1 and not htfAllowSell ? "Bearish BOS but HTF bullish - wait" :
         bosDir == 1 and not pdAllowBuy ? "Bullish BOS but in premium - wait" :
         bosDir == -1 and not pdAllowSell ? "Bearish BOS but in discount - wait" :
         "Waiting for setup"
    table.cell(d, 0, 9, "ACTION", text_color=yl, text_size=size.normal, bgcolor=color.new(color.black, 0))
    table.cell(d, 1, 9, actionStr, text_color=wh, text_size=size.small, bgcolor=color.new(color.black, 0))

// ────────────────────────────────────────────────────────────
// ALERTS
// ────────────────────────────────────────────────────────────

alertcondition(bullBOS, "Bullish BOS", "Bullish Break of Structure")
alertcondition(bearBOS, "Bearish BOS", "Bearish Break of Structure")
alertcondition(buySignal, "Buy Entry", "BUY - FVG retest after BOS, HTF aligned, in discount")
alertcondition(sellSignal, "Sell Entry", "SELL - FVG retest after BOS, HTF aligned, in premium")
alertcondition(buySignal and entrySB, "Buy Silver Bullet", "BUY * Silver Bullet window")
alertcondition(sellSignal and entrySB, "Sell Silver Bullet", "SELL * Silver Bullet window")
